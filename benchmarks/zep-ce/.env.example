# Zep CE Benchmark Environment
# Copy to .env and fill in values

# ---- OpenAI API key (REQUIRED) ----
# Graphiti 0.3 uses OpenAI for BOTH LLM (chat completions) AND embeddings.
# The embedder is hardcoded to OpenAI — no base_url override available.
# So you MUST have an OpenAI API key even if using a different LLM provider.
OPENAI_API_KEY=sk-your-key-here

# ---- LLM model (optional overrides) ----
# OPENAI_BASE_URL=              # leave empty for default OpenAI
# MODEL_NAME=gpt-4o-mini        # default model for Graphiti knowledge extraction

# ---- Alternative LLM (chat only, embeddings still use OpenAI) ----
# To use Gemini/local LLM for chat but OpenAI for embeddings:
# OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# MODEL_NAME=gemini-2.0-flash
# NOTE: OPENAI_API_KEY must still be a valid OpenAI key for embeddings
