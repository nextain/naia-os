[package]
name = "tauri-plugin-stt"
version = "0.1.1"
authors = ["Affex Team"]
description = "Speech-to-text recognition plugin for Tauri with multi-language support"
edition = "2021"
rust-version = "1.77.2"
license = "MIT"
repository = "https://github.com/brenogonzaga/tauri-plugin-stt"
homepage = "https://github.com/brenogonzaga/tauri-plugin-stt"
documentation = "https://docs.rs/tauri-plugin-stt"
exclude = ["/examples", "/dist-js", "/guest-js", "/node_modules"]
links = "tauri-plugin-stt"
keywords = ["tauri", "speech", "recognition", "stt", "vosk"]
categories = ["multimedia::audio", "api-bindings"]

[dependencies]
tauri = { version = "2.10.3" }
serde = "1.0"
thiserror = "2"
serde_json = "1.0"
log = "0.4"

[target.'cfg(any(target_os = "linux", target_os = "windows"))'.dependencies]
cpal = "0.17"
vosk = "0.3"
reqwest = { version = "0.12", features = ["blocking"] }
zip = "6.0.0"
whisper-rs = { git = "https://github.com/nextain/whisper-rs-fork.git", rev = "ab97b92" }

[build-dependencies]
tauri-plugin = { version = "2.5.4", features = ["build"] }
zip = "6.0.0"
