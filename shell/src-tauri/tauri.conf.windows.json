{
	"build": {
		"beforeBuildCommand": ""
	},
	"bundle": {
		"targets": ["nsis", "msi"],
		"resources": {
			"resources/node.exe": "node.exe"
		},
		"windows": {
			"certificateThumbprint": null,
			"digestAlgorithm": "sha256",
			"nsis": {
				"installMode": "currentUser"
			},
			"fileAssociations": [
				{
					"ext": ["md"],
					"mimeType": "text/markdown",
					"name": "Markdown Document",
					"description": "Naia Markdown Viewer",
					"role": "Viewer"
				}
			]
		}
	}
}
